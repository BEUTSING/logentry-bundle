{
    "name": "beutsing/log-entry-bundle",
    "description": "Recording of user activities.",
    "type": "symfony-bundle",
    "require": {
        "symfony/framework-bundle": "^7.0",
        "doctrine/orm": "^3.0",
        "symfony/security-bundle": "^7.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Beutsing\\LogEntryBundle\\": "src/"
        }
    },
    "minimum-stability": "stable",

    "scripts": {
    "post-install-cmd": [
       "@echo 'LogEntryBundle installed successfully.'",
       "@echo 'Run the following command to create the table:'",
       "@echo 'php bin/console make:migration'",
       "@echo 'php bin/console doctrine:migrations:migrate'"

   ],
   "post-update-cmd": [ 
        "@echo 'LogEntryBundle installed successfully.'", 
        "@echo 'Run the following command to create the table:'", 
        "@echo 'php bin/console make:migration'", 
        "@echo 'php bin/console doctrine:migrations:migrate'" ]
    }
}
